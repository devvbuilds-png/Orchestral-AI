# ── Core ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DATABASE_URL=postgres://user:pass@host:5432/orchestral-ai
PORT=5000

# ── Sessions / Auth ─────────────────────────────────────────────────────────
# REQUIRED in production — the server refuses to start without it (audit S3).
SESSION_SECRET=replace-with-a-long-random-string
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
APP_URL=http://localhost:5000

# ── Supabase Storage (PKB + uploads buckets) ────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=...

# ── GitHub (Vibe Coder mode) ────────────────────────────────────────────────
# Optional. Without it, GitHub import is limited to 60 req/hr (≈ a few repos).
# A fine-grained or classic PAT with public-repo read raises this to 5000/hr.
# Users can also paste their own token in the import dialog.
GITHUB_TOKEN=
